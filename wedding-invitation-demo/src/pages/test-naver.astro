<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <!-- Referer를 무조건 보내도록 설정 -->
    <meta name="referrer" content="always">
    <title>네이버 지도 정밀 진단</title>
    <style>
        body { font-family: sans-serif; padding: 20px; }
        .box { padding: 15px; margin-bottom: 10px; border-radius: 8px; border: 1px solid #ccc; }
        .error { background: #fee2e2; color: #991b1b; border-color: #f87171; }
        .success { background: #f0fdf4; color: #166534; border-color: #86efac; }
        .info { background: #e0f2fe; color: #075985; border-color: #7dd3fc; }
    </style>
</head>
<body>
    <h1>네이버 지도 정밀 진단</h1>
    
    <div id="uri-check" class="box info">현재 요청 URI: <strong id="current-uri">확인 중...</strong></div>
    <div id="step1" class="box">1. 스크립트 로드 확인 중...</div>
    <div id="step2" class="box">2. naver 객체 확인 중...</div>
    
    <div id="map" style="width:100%; height:400px; background:#eee; margin-top:20px;"></div>

    <!-- 서브모듈 제거 (인증 범위 축소) -->
    <script is:inline 
        src="https://oapi.map.naver.com/openapi/v3/maps.js?ncpKeyId=oya3z2iso0"
        onload="document.getElementById('step1').innerText = '✅ 스크립트 파일 수신 완료! (네트워크 OK)'; document.getElementById('step1').className = 'box success';"
        onerror="document.getElementById('step1').innerText = '❌ 스크립트 로드 실패! (주소 확인 필요)'; document.getElementById('step1').className = 'box error';"
    ></script>

    <script is:inline>
        // 네이버 지도 인증 실패 시 호출되는 전역 함수
        window.navermap_authFailure = function () {
            const step2 = document.getElementById('step2');
            step2.innerText = '❌ 네이버 지도 인증 실패! (NCP 콘솔의 Web 서비스 URL 설정을 확인하세요)';
            step2.className = 'box error';
            console.error("Naver Map Auth Failure: Check your Client ID and Registered URL (Referer).");
        };

        document.getElementById('current-uri').innerText = window.location.href;
        window.onload = function() {
            const step2 = document.getElementById('step2');
            if (typeof naver !== 'undefined' && naver.maps) {
                step2.innerText = '✅ naver.maps 객체 인증 성공! (객체 생성됨)';
                step2.className = 'box success';
                
                try {
                    var map = new naver.maps.Map('map', {
                        center: new naver.maps.LatLng(37.3595704, 127.105399),
                        zoom: 15
                    });
                    console.log("지도 생성 시도 완료");
                } catch (e) {
                    console.error("지도 생성 중 오류:", e);
                    step2.innerText = '❌ 객체는 있으나 지도 생성 실패: ' + e.message;
                    step2.className = 'box error';
                }
            } else {
                step2.innerText = '❌ naver 객체 인증 실패 (NCP URL 등록 문제 또는 Client ID 오류)';
                step2.className = 'box error';
            }
        };
    </script>
</body>
</html>
