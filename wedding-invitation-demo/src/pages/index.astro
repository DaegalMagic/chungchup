									</div>
								</div>
							</div>
						</div>

						<!-- D-Day 섹션 (하단 고정 느낌) -->
						<div class="mt-8 mb-4">
							<div class="text-center bg-gray-900 rounded-lg p-4">
								<div id="d-day-display" class="text-2xl font-bold text-white mb-1">D-DAY</div>
								<p class="text-[10px] text-gray-400">2026. 08. 22. (토)</p>
							</div>
						</div>
					</section>
				</div>

			</div>

			<nav id="tab-bar" class="flex-shrink-0 bg-white border-t border-gray-100 safe-area-bottom" style="margin: 0 10px;">
				<div class="flex justify-around items-center h-16">
					<button class="tab-btn active flex flex-col items-center justify-center flex-1 h-full" data-tab="home">
						<span class="text-[clamp(14px,4.5vw,18px)] font-bold leading-[1.2] tracking-tighter">소개</span>
					</button>
					<button class="tab-btn flex flex-col items-center justify-center flex-1 h-full" data-tab="gallery">
						<span class="text-[clamp(14px,4.5vw,18px)] font-bold leading-[1.2] tracking-tighter">사진첩</span>
					</button>
					<button class="tab-btn flex flex-col items-center justify-center flex-1 h-full" data-tab="location">
						<span class="text-[clamp(14px,4.5vw,18px)] font-bold leading-[1.2] tracking-tighter">오시는 길</span>
					</button>
					<button class="tab-btn flex flex-col items-center justify-center flex-1 h-full" data-tab="heart">
						<span class="text-[clamp(14px,4.5vw,18px)] font-bold leading-[1.2] tracking-tighter">연락처</span>
					</button>
				</div>
			</nav>

		</main>

		<style is:global>
			#petal-container {
				position: absolute;
				top: 0;
				left: 0;
				width: 100%;
				height: 100%;
				pointer-events: none;
				z-index: 20;
				overflow: hidden;
			}
			.petal {
				position: absolute;
				background: rgba(230, 230, 230, 0.5);
				border-radius: 40% 60% 60% 40% / 60% 40% 60% 40%;
				animation-name: fall;
				animation-timing-function: linear;
				animation-iteration-count: infinite;
			}
			@keyframes fall {
				from { transform: translateY(-20vh) translateX(var(--sway-start)) rotate(var(--rotate-start)); }
				to { transform: translateY(110vh) translateX(var(--sway-end)) rotate(var(--rotate-end)); }
			}
			.scrollbar-hide::-webkit-scrollbar { display: none; }
			.scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }
		</style>

		<style>
			.tab-panel {
				position: absolute;
				top: 0;
				left: 0;
				width: 100%;
				height: 100%;
				background-color: white;
				border: 1px solid #e5e7eb;
				border-radius: 12px;
				overflow-y: auto;
				overflow-x: hidden;
				transform-style: preserve-3d;
				transform-origin: center -30px;
				transition: transform 0.7s cubic-bezier(0.4, 0, 0.2, 1);
				backface-visibility: hidden;
				scrollbar-width: none;
			}
			.tab-panel:not(#tab-cover) { background-color: white; }
			#tab-home { z-index: 4; }
			#tab-gallery { z-index: 3; }
			#tab-location { z-index: 2; }
			#tab-heart { z-index: 1; }
			.tab-panel.active { transform: rotateX(0deg); }
			.tab-panel.flipped { transform: rotateX(90deg); }
			.tab-panel.hidden-flipped { transform: rotateX(90deg); }
			.tab-panel.hidden-under { transform: rotateX(0deg); }
			.tab-btn { color: #9ca3af; transition: color 0.2s; }
			.tab-btn.active { color: #111827; }
			.map-tab { background-color: #f9fafb; color: #9ca3af; border: 1px solid #f3f4f6; }
			.map-tab.active { background-color: white; color: #111827; border-color: #e5e7eb; border-top-color: white; z-index: 5; }
			.notebook-rings { position: absolute; top: 10px; left: 10px; right: 10px; display: flex; justify-content: space-around; padding: 0 10%; z-index: 10; }
			.ring { width: 12px; height: 22px; border: 2px solid #e5e7eb; border-bottom: none; border-radius: 6px 6px 0 0; }
		</style>

		<script is:inline>
			document.addEventListener('DOMContentLoaded', function() {
				const tabBtns = document.querySelectorAll('.tab-btn');
				const tabPanels = document.querySelectorAll('.tab-panel');
				const tabOrder = ['home', 'gallery', 'location', 'heart'];
				let currentPage = 0;
				let isAnimating = false;
				let canFlip = false;

				function initPages() {
					tabPanels.forEach((panel) => {
						if (panel.id !== 'tab-cover') panel.classList.add('hidden-under');
					});
				}
				initPages();

				async function flipToPage(targetIndex) {
					if (isAnimating || !canFlip || targetIndex === currentPage) return;
					isAnimating = true;
					const animationDuration = 100;
					const stepDuration = 100;
					if (targetIndex > currentPage) {
						for (let i = currentPage; i < targetIndex; i++) {
							const pageToFlip = document.getElementById('tab-' + tabOrder[i]);
							pageToFlip.classList.remove('active', 'hidden-under');
							pageToFlip.classList.add('flipped');
							await new Promise(res => setTimeout(res, stepDuration));
						}
					} else {
						for (let i = currentPage - 1; i >= targetIndex; i--) {
							const pageToUnflip = document.getElementById('tab-' + tabOrder[i]);
							pageToUnflip.classList.remove('flipped', 'hidden-flipped');
							pageToUnflip.classList.add('active');
							await new Promise(res => setTimeout(res, stepDuration));
						}
					}

					await new Promise(res => setTimeout(res, animationDuration));
					currentPage = targetIndex;
					tabPanels.forEach((panel) => {
						if (panel.id === 'tab-cover') return;
						const panelIndex = parseInt(panel.dataset.page, 10);
						panel.classList.remove('active', 'flipped', 'hidden-flipped', 'hidden-under');
						if (panelIndex === currentPage) {
							panel.classList.add('active');
						} else if (panelIndex < currentPage) {
							panel.classList.add('hidden-flipped');
						} else {
							panel.classList.add('hidden-under');
						}
					});
					const targetPanel = document.getElementById('tab-' + tabOrder[targetIndex]);
					if(targetPanel) targetPanel.scrollTop = 0;
                    
                    if (tabOrder[targetIndex] === 'location') {
                        setTimeout(() => {
                            if (window.mapInstance) {
                                window.mapInstance.relayout();
                                window.mapInstance.setCenter(new kakao.maps.LatLng(37.2709214, 127.0661671));
                            }
                            
                            // 네이버 지도 레이지 로딩
                            const activeMapTab = document.querySelector('.map-tab.active');
                            if (activeMapTab && activeMapTab.dataset.map === 'naver') {
                                if (!window.naverMapInstance) {
                                    initNaverMap();
                                } else {
                                    window.naverMapInstance.updateBy(null, true);
                                    window.naverMapInstance.setCenter(new naver.maps.LatLng(37.2709214, 127.0661671));
                                }
                            }
                        }, 500);
                    }

					isAnimating = false;
				}

				tabBtns.forEach((btn, index) => {
					btn.addEventListener('click', function() {
						if (!canFlip) return;
						const targetTab = this.getAttribute('data-tab');
						const targetIndex = tabOrder.indexOf(targetTab);
						updateTabButtons(targetIndex);
						flipToPage(targetIndex);
					});
				});

				function updateTabButtons(index) {
					tabBtns.forEach((b, i) => {
						if (i === index) b.classList.add('active');
						else b.classList.remove('active');
					});
				}

                const mapTabs = document.querySelectorAll('.map-tab');
                const mapViews = document.querySelectorAll('.map-view');
                const routeBtn = document.getElementById('route-btn');
                const routeUrls = {
                    kakao: 'https://map.kakao.com/link/to/아이티컨벤션,37.2709214,127.0661671',
                    naver: 'https://map.naver.com/p/entry/place/33989425',
                    google: 'https://www.google.com/maps/dir/?api=1&destination=아이티컨벤션'
                };

                mapTabs.forEach(tab => {
                    tab.addEventListener('click', () => {
                        const target = tab.dataset.map;
                        mapTabs.forEach(t => t.classList.remove('active'));
                        tab.classList.add('active');
                        mapViews.forEach(v => v.style.display = 'none');
                        const targetView = document.getElementById('map-' + target);
                        if (targetView) targetView.style.display = 'block';
                        routeBtn.href = routeUrls[target];

                        if (target === 'kakao' && window.mapInstance) {
                            window.mapInstance.relayout();
                            window.mapInstance.setCenter(new kakao.maps.LatLng(37.2709214, 127.0661671));
                        }
                        if (target === 'naver') {
                            if (!window.naverMapInstance) {
                                initNaverMap();
                            } else {
                                setTimeout(() => {
                                    window.naverMapInstance.updateBy(null, true);
                                    window.naverMapInstance.setCenter(new naver.maps.LatLng(37.2709214, 127.0661671));
                                }, 50);
                            }
                        }
                    });
                });

                // 카카오맵 초기화 로직 복구
                function initKakaoMap() {
                    var container = document.getElementById('map-kakao');
                    var options = {
                        center: new kakao.maps.LatLng(37.2709214, 127.0661671),
                        level: 3
                    };
                    window.mapInstance = new kakao.maps.Map(container, options);
                    var markerPosition = new kakao.maps.LatLng(37.2709214, 127.0661671);
                    var marker = new kakao.maps.Marker({ position: markerPosition });
                    marker.setMap(window.mapInstance);
                    var infowindow = new kakao.maps.InfoWindow({
                        content: '<div style="padding:5px;font-size:12px;text-align:center;width:150px;color:#000;background:#fff;border:1px solid #ccc;">아이티 컨벤션</div>'
                    });
                    infowindow.open(window.mapInstance, marker);
                }

                // 네이버 지도 초기화 로직 복구
                function initNaverMap() {
                    const mapContainer = document.getElementById('map-naver');
                    if (!mapContainer || typeof naver === 'undefined' || !naver.maps) return;
                    if (mapContainer.offsetWidth === 0) {
                        setTimeout(initNaverMap, 100);
                        return;
                    }
                    const center = new naver.maps.LatLng(37.2709214, 127.0661671);
                    window.naverMapInstance = new naver.maps.Map(mapContainer, {
                        center: center,
                        zoom: 15,
                        autoResize: true
                    });
                    const marker = new naver.maps.Marker({ position: center, map: window.naverMapInstance });
                    const infowindow = new naver.maps.InfoWindow({
                        content: '<div style="padding:10px;font-size:12px;text-align:center;width:150px;color:#000;background:#fff;border:1px solid #ccc;border-radius:5px;">아이티 컨벤션</div>'
                    });
                    infowindow.open(window.naverMapInstance, marker);
                }

                if (typeof kakao !== 'undefined' && kakao.maps) {
                    kakao.maps.load(initKakaoMap);
                }

				let lastFlipTime = 0;
				const flipCooldown = 500;
				let galleryScrollEdge = null; // 'top' or 'bottom' or null
				let lastWheelTime = 0;

				function handleDirectionalFlip(direction) {
					const now = Date.now();
					if (isAnimating || !canFlip || (now - lastFlipTime < flipCooldown)) return;
					let targetIndex = currentPage;
					if (direction === 'next' && currentPage < tabOrder.length - 1) targetIndex++;
					else if (direction === 'prev' && currentPage > 0) targetIndex--;
					if (targetIndex !== currentPage) {
						lastFlipTime = now;
						galleryScrollEdge = null; // 페이지 넘김 시 플래그 초기화
						updateTabButtons(targetIndex);
						flipToPage(targetIndex);
					}
				}

				window.addEventListener('wheel', (e) => {
					if (!canFlip) return;
					if (e.target.closest('.map-view')) return;
					
					const galleryTab = e.target.closest('#tab-gallery');
					if (galleryTab) {
						const scrollContainer = galleryTab.querySelector('.overflow-y-auto');
						if (scrollContainer && e.target.closest('.overflow-y-auto')) {
							const isAtTop = scrollContainer.scrollTop <= 2;
							const isAtBottom = Math.abs(scrollContainer.scrollHeight - scrollContainer.clientHeight - scrollContainer.scrollTop) < 5;
							
							if (e.deltaY < 0 && isAtTop) {
								if (galleryScrollEdge === 'top') handleDirectionalFlip('prev');
								else galleryScrollEdge = 'top';
								return;
							} else if (e.deltaY > 0 && isAtBottom) {
								if (galleryScrollEdge === 'bottom') handleDirectionalFlip('next');
								else galleryScrollEdge = 'bottom';
								return;
							}
							galleryScrollEdge = null;
							return;
						} else {
							if (e.deltaY > 0) handleDirectionalFlip('next');
							else if (e.deltaY < 0) handleDirectionalFlip('prev');
							return;
						}
					}

					if (e.deltaY > 0) handleDirectionalFlip('next');
					else if (e.deltaY < 0) handleDirectionalFlip('prev');
				}, { passive: true });

				let touchStartY = 0;
				window.addEventListener('touchstart', (e) => {
					if (!canFlip) return;
					if (e.target.closest('.map-view')) return;
					touchStartY = e.touches[0].clientY;
				}, { passive: true });

				window.addEventListener('touchend', (e) => {
					if (!canFlip) return;
					if (e.target.closest('.map-view')) return;
					
					const touchEndY = e.changedTouches[0].clientY;
					const diff = touchStartY - touchEndY;
					if (Math.abs(diff) < 50) return;

					const galleryTab = e.target.closest('#tab-gallery');
					if (galleryTab) {
						const scrollContainer = galleryTab.querySelector('.overflow-y-auto');
						if (scrollContainer && e.target.closest('.overflow-y-auto')) {
							const isAtTop = scrollContainer.scrollTop <= 2;
							const isAtBottom = Math.abs(scrollContainer.scrollHeight - scrollContainer.clientHeight - scrollContainer.scrollTop) < 5;

							if (diff < 0 && isAtTop) {
								if (galleryScrollEdge === 'top') handleDirectionalFlip('prev');
								else galleryScrollEdge = 'top';
								return;
							} else if (diff > 0 && isAtBottom) {
								if (galleryScrollEdge === 'bottom') handleDirectionalFlip('next');
								else galleryScrollEdge = 'bottom';
								return;
							}
							galleryScrollEdge = null;
							return;
						} else {
							if (diff > 0) handleDirectionalFlip('next');
							else if (diff < 0) handleDirectionalFlip('prev');
							return;
						}
					}

					if (diff > 0) handleDirectionalFlip('next');
					else if (diff < 0) handleDirectionalFlip('prev');
				}, { passive: true });

				const accHeaders = document.querySelectorAll('.acc-header');
				accHeaders.forEach(header => {
					header.addEventListener('click', () => {
						const item = header.parentElement;
						const content = item.querySelector('.acc-content');
						const icon = item.querySelector('.acc-icon');
						const isOpen = !content.classList.contains('hidden');
						document.querySelectorAll('.acc-content').forEach(c => c.classList.add('hidden'));
						document.querySelectorAll('.acc-icon').forEach(i => i.style.transform = 'rotate(0deg)');
						if (!isOpen) {
							content.classList.remove('hidden');
							icon.style.transform = 'rotate(90deg)';
						}
					});
				});

				// 복사 기능 추가
				document.querySelectorAll('.copy-btn').forEach(btn => {
					btn.addEventListener('click', () => {
						const text = btn.getAttribute('data-copy');
						navigator.clipboard.writeText(text).then(() => {
							const originalText = btn.innerText;
							btn.innerText = '완료';
							btn.classList.add('bg-gray-900', 'text-white');
							setTimeout(() => {
								btn.innerText = originalText;
								btn.classList.remove('bg-gray-900', 'text-white');
							}, 1500);
						});
					});
				});

				// 메인 사진 토글 로직
				const mainPhoto = document.getElementById('main-photo');
				if (mainPhoto) {
					let isToggled = false;
					mainPhoto.parentElement.addEventListener('click', () => {
						isToggled = !isToggled;
						mainPhoto.style.backgroundImage = isToggled 
							? "url('/chungchup/image/43.jpg')" 
							: "url('/chungchup/image/1.jpg')";
					});
				}

				// D-day 계산 로직
				const dDayDisplay = document.getElementById('d-day-display');
				if (dDayDisplay) {
					const targetDate = new Date('2026-08-22T11:00:00');
					const today = new Date();
					const diff = targetDate - today;
					const days = Math.ceil(diff / (1000 * 60 * 60 * 24));
					dDayDisplay.innerText = days > 0 ? `D-${days}` : days === 0 ? 'D-DAY' : `D+${Math.abs(days)}`;
				}

				window.addEventListener('curtain-animation-finished', () => {
					setTimeout(() => {
						const coverPage = document.getElementById('tab-cover');
						const homePage = document.getElementById('tab-home');
						if (coverPage && homePage) {
							coverPage.classList.remove('active');
							coverPage.classList.add('flipped');
							homePage.classList.remove('hidden-under');
							homePage.classList.add('active');
							canFlip = true;
						}
					}, 1400);
				});
			});
		</script>
		<script src="/chungchup/curtain-animation.js" is:inline></script>
	</body>
</html>